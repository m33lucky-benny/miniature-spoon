                Ebiya.sg
              </div>
              <div class="text-xs text-gray-500 leading-tight hidden sm:block">
                Payment Systems Consulting
              </div>
            </div>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-8">
            <a
              href="#services"
              class="nav-link text-sm font-medium text-gray-600 hover:text-primary transition-colors"
              >Services</a
            >
            <a
              href="#assessment"
              class="nav-link text-sm font-medium text-gray-600 hover:text-primary transition-colors"
              >Free Assessment</a
            >
            <a
              href="#about"
              class="nav-link text-sm font-medium text-gray-600 hover:text-primary transition-colors"
              >About</a
            >
            <a
              href="#contact"
              class="nav-link text-sm font-medium text-gray-600 hover:text-primary transition-colors"
              >Contact</a
            >
            <a
              href="http://154.43.52.68:3000"
              target="_blank"
              rel="noopener noreferrer"
              class="gradient-bg text-white text-sm font-semibold px-5 py-2.5 rounded-xl hover:opacity-90 transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5"
            >
              <i class="fa-solid fa-rocket mr-1.5"></i>Free Assessment
            </a>
          </nav>

          <!-- Mobile Hamburger -->
          <button
            id="menu-btn"
            class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100 transition-colors"
            aria-label="Toggle menu"
          >
            <i class="fa-solid fa-bars text-xl" id="menu-icon"></i>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="md:hidden border-t border-gray-100 py-4">
          <nav class="flex flex-col gap-1">
            <a
              href="#services"
              class="px-4 py-3 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors mobile-nav-link"
            >
              <i class="fa-solid fa-briefcase mr-2 text-primary/60 w-4"></i
              >Services
            </a>
            <a
              href="#assessment"
              class="px-4 py-3 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors mobile-nav-link"
            >
              <i class="fa-solid fa-chart-bar mr-2 text-primary/60 w-4"></i>Free
              Assessment
            </a>
            <a
              href="#about"
              class="px-4 py-3 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors mobile-nav-link"
            >
              <i class="fa-solid fa-user mr-2 text-primary/60 w-4"></i>About
            </a>
            <a
              href="#contact"
              class="px-4 py-3 text-sm font-medium text-gray-600 hover:text-primary hover:bg-gray-50 rounded-lg transition-colors mobile-nav-link"
            >
              <i class="fa-solid fa-envelope mr-2 text-primary/60 w-4"></i
              >Contact
            </a>
            <div class="px-4 pt-2">
              <a
                href="http://154.43.52.68:3000"
                target="_blank"
                rel="noopener noreferrer"
                class="block gradient-bg text-white text-sm font-semibold px-5 py-3 rounded-xl text-center hover:opacity-90 transition-all shadow-md"
              >
                <i class="fa-solid fa-rocket mr-1.5"></i>Start Free Assessment
              </a>
            </div>
          </nav>
        </div>
      </div>
    </header>

    <!-- ===== HERO ===== -->
    <section
      id="home"
      class="hero-pattern pt-24 pb-20 md:pt-32 md:pb-28 text-white relative overflow-hidden"
    >
      <!-- Decorative blobs -->
      <div
        class="absolute top-10 right-10 w-64 h-64 bg-white/5 rounded-full blur-3xl pointer-events-none"
      ></div>
      <div
        class="absolute bottom-10 left-10 w-48 h-48 bg-accent/10 rounded-full blur-2xl pointer-events-none"
      ></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Text -->
          <div class="fade-in">
            <div
              class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm font-medium mb-6"
            >
              <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
              Southeast Asia Payment Specialists
