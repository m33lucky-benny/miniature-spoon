                  </div>
                  <div class="ml-auto text-3xl font-bold text-accent">72</div>
                </div>
                <div class="space-y-2.5">
                  <div>
                    <div
                      class="flex justify-between text-xs text-white/70 mb-1"
                    >
                      <span>Coverage & Reach</span><span>65%</span>
                    </div>
                    <div class="h-1.5 bg-white/20 rounded-full">
                      <div class="h-full w-[65%] bg-accent rounded-full"></div>
                    </div>
                  </div>
                  <div>
                    <div
                      class="flex justify-between text-xs text-white/70 mb-1"
                    >
                      <span>Routing Efficiency</span><span>78%</span>
                    </div>
                    <div class="h-1.5 bg-white/20 rounded-full">
                      <div class="h-full w-[78%] bg-primary rounded-full"></div>
                    </div>
                  </div>
                  <div>
                    <div
                      class="flex justify-between text-xs text-white/70 mb-1"
                    >
                      <span>Cost Optimization</span><span>55%</span>
                    </div>
                    <div class="h-1.5 bg-white/20 rounded-full">
                      <div
                        class="h-full w-[55%] bg-yellow-400 rounded-full"
                      ></div>
                    </div>
                  </div>
                  <div>
                    <div
                      class="flex justify-between text-xs text-white/70 mb-1"
                    >
                      <span>Local Wallets</span><span>40%</span>
                    </div>
                    <div class="h-1.5 bg-white/20 rounded-full">
                      <div class="h-full w-[40%] bg-red-400 rounded-full"></div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Floating badge -->
              <div
                class="absolute -top-4 -right-4 bg-accent text-white rounded-xl px-3 py-2 shadow-lg text-sm font-bold"
              >
                <i class="fa-solid fa-arrow-trend-up mr-1"></i>+23% Revenue
