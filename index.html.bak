            class="card-hover bg-white rounded-2xl p-8 shadow-xl border-2 border-primary relative fade-in"
          >
            <div class="popular-badge">★ MOST POPULAR</div>
            <div
              class="w-14 h-14 gradient-bg rounded-2xl flex items-center justify-center mb-6 shadow-lg"
            >
