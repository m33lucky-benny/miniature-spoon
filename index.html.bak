<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Payment Systems Consulting | Ebiya.sg - Southeast Asia Payment
      Infrastructure Experts
    </title>
    <meta
      name="description"
      content="Professional payment systems consulting for Southeast Asia merchants. 20+ years experience from VISA, PayPal. Free assessment tool for OTAs, hotels, e-commerce."
    />
    <meta
      name="keywords"
      content="payment systems, southeast asia, fintech consulting, payment gateway, PSP, GrabPay, TouchNGo, DANA, Singapore payments"
    />
    <meta name="author" content="Ebiya.sg Payment Consulting" />
    <!-- Open Graph -->
    <meta property="og:title" content="Payment Systems Consulting | Ebiya.sg" />
    <meta
      property="og:description"
      content="Professional payment systems consulting for Southeast Asia merchants. 20+ years experience from VISA, PayPal. Free assessment tool."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://payments.ebiya.sg" />
    <meta
      property="og:image"
      content="https://payments.ebiya.sg/og-image.jpg"
    />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Payment Systems Consulting | Ebiya.sg"
    />
    <meta
      name="twitter:description"
      content="20+ years VISA, PayPal experience. Free payment assessment for SEA merchants."
    />
    <!-- Schema Markup -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Ebiya.sg Payment Consulting",
        "description": "Professional payment systems consulting for Southeast Asia merchants",
        "url": "https://payments.ebiya.sg",
        "telephone": "+6587776638",
        "email": "ebiya.sg@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "55 Changi Road, Unit B1-01",
          "addressLocality": "Singapore",
          "addressCountry": "SG"
        },
        "areaServed": [
          "Singapore",
          "Malaysia",
          "Thailand",
          "Indonesia",
          "Vietnam",
          "Philippines"
        ],
        "serviceType": [
          "Payment Systems Consulting",
          "PSP Integration",
          "Payment Infrastructure Optimization"
        ]
      }
    </script>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: "#667eea",
              secondary: "#764ba2",
              accent: "#10b981",
            },
            fontFamily: {
              sans: [
                "-apple-system",
                "BlinkMacSystemFont",
                "Segoe UI",
                "Roboto",
                "Helvetica Neue",
                "Arial",
                "sans-serif",
              ],
            },
          },
        },
      };
    </script>
    <style>
      /* Gradient utilities */
      .gradient-bg {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      }
      .gradient-text {
        background: linear-gradient(135deg, #667eea, #764ba2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .gradient-card {
        background: linear-gradient(135deg, #667eea15, #764ba215);
      }

      /* Hero pattern */
      .hero-pattern {
        background-color: #667eea;
        background-image:
          radial-gradient(
            circle at 20% 80%,
            rgba(118, 75, 162, 0.4) 0%,
            transparent 50%
          ),
          radial-gradient(
            circle at 80% 20%,
            rgba(102, 126, 234, 0.6) 0%,
            transparent 50%
          ),
          radial-gradient(
            circle at 50% 50%,
            rgba(16, 185, 129, 0.1) 0%,
            transparent 70%
          );
        background-size: cover;
      }

      /* Card hover */
      .card-hover {
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }
      .card-hover:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(102, 126, 234, 0.2);
      }

      /* Nav link underline animation */
      .nav-link {
        position: relative;
      }
      .nav-link::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background: #667eea;
        transition: width 0.3s ease;
      }
      .nav-link:hover::after {
        width: 100%;
      }

      /* Smooth scroll */
      html {
        scroll-behavior: smooth;
      }

      /* Section fade-in */
      .fade-in {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.6s ease,
          transform 0.6s ease;
      }
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Stats counter */
      .stat-item {
        border-right: 1px solid rgba(255, 255, 255, 0.2);
      }
      .stat-item:last-child {
        border-right: none;
      }

      /* Popular badge */
      .popular-badge {
        background: linear-gradient(135deg, #10b981, #059669);
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        padding: 4px 20px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
        color: white;
        letter-spacing: 0.05em;
      }

      /* Assessment feature list */
      .feature-check {
        color: #10b981;
      }

      /* Form focus */
      .form-input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.15);
      }

      /* Print */
      @media print {
        .no-print {
          display: none !important;
        }
        .gradient-bg {
          background: #667eea !important;
          -webkit-print-color-adjust: exact;
        }
      }

      /* Mobile menu */
      #mobile-menu {
        display: none;
      }
      #mobile-menu.open {
        display: block;
      }

      /* Scroll indicator */
      .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0;
        height: 3px;
        background: linear-gradient(90deg, #667eea, #10b981);
        z-index: 9999;
        transition: width 0.1s ease;
      }

      /* Logo placeholder */
      .logo-placeholder {
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        border: 2px dashed #cbd5e1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        padding: 20px;
      }
    </style>
  </head>
  <body class="font-sans text-gray-800 bg-white">
    <!-- Scroll Progress -->
    <div class="scroll-progress" id="scroll-progress"></div>

    <!-- ===== HEADER / NAV ===== -->
    <header
